---
import { homeAdConfig } from "@/config/ads";

interface Props {
  adId?: string;
  alt?: string;
  class?: string;
  href?: string;
  imageSrc?: string;
  placement?: string;
  rounded?: boolean;
}

const defaultAd = homeAdConfig.ads[0];
const {
  adId = defaultAd.id,
  alt = defaultAd.alt,
  class: className = "",
  href = defaultAd.href,
  imageSrc = defaultAd.imageSrc,
  placement = "home_header",
  rounded = true,
} = Astro.props;
const roundedClass = rounded ? "rounded-sm" : "";
---

<a
  data-ad-banner
  data-ad-id={adId}
  data-ad-placement={placement}
  data-ad-href={href}
  data-analytics-event="ad_click"
  data-analytics-category="ad"
  data-analytics-label={placement}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class={`relative block overflow-hidden ${roundedClass} ${className}`}
  aria-label="广告"
>
  <img
    src={imageSrc}
    alt={alt}
    class="block h-auto w-full"
    decoding="async"
  >
  <span
    class="absolute right-1.5 bottom-1.5 inline-flex items-center gap-1 rounded-full bg-surface-base/75 px-1.5 py-0.5 text-[10px] leading-none font-medium text-text-main ring-1 ring-white/15 backdrop-blur-sm"
  >
    <i class="mgc_information_line text-xs" aria-hidden="true"></i>
    广告
  </span>
</a>

<script>
  import { trackEvent } from "@/scripts/analytics";

  const observedAds = new WeakSet<Element>();
  const exposedAds = new WeakSet<Element>();
  const banners = document.querySelectorAll<HTMLElement>("[data-ad-banner]");

  if ("IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting || exposedAds.has(entry.target)) {
            continue;
          }

          exposedAds.add(entry.target);
          observer.unobserve(entry.target);

          if (entry.target instanceof HTMLElement) {
            trackEvent("ad_exposure", {
              event_category: "ad",
              event_label: entry.target.dataset.adPlacement,
              ad_id: entry.target.dataset.adId,
              ad_placement: entry.target.dataset.adPlacement,
              ad_href: entry.target.dataset.adHref,
            });
          }
        }
      },
      { threshold: 0.5 }
    );

    for (const banner of banners) {
      if (!observedAds.has(banner)) {
        observedAds.add(banner);
        observer.observe(banner);
      }
    }

    document.addEventListener("astro:before-swap", () => observer.disconnect(), { once: true });
  }
</script>
